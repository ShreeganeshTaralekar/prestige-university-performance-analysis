      <column caption='Total Enrollment' datatype='integer' name='[Calculation_2134143328485011456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([enrollment_id])' />
      </column>
      <column caption='Average GPA' datatype='real' name='[Calculation_2134143328485216257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([final_grade])' />
      </column>
      <column caption='DFW Flag' datatype='integer' name='[Calculation_2134143328485359618]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [grade_letter] = &quot;D&quot; OR [grade_letter] = &quot;F&quot; OR [status] = &quot;Withdrawn&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='DFW Rate' datatype='real' name='[Calculation_2134143328485519363]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_2134143328485359618]) / COUNT([enrollment_id])' />
      </column>
      <column caption='Total Credit Earned' datatype='integer' name='[Calculation_2134143328485703684]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([credits_earned])' />
      </column>
      <column caption='Time to Degree (Years)' datatype='integer' name='[Calculation_2134143328485896197]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;, [admission_date], [expected_grad_date])' />
      </column>
      <column caption='Enrollment Capacity' datatype='integer' name='[Calculation_2134143328486207494]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([course_id]) * 50' />
      </column>
      <column caption='Utilization %' datatype='real' name='[Calculation_2134143328486375431]' role='measure' type='quantitative'>
